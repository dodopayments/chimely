  "query": "SELECT e.slug AS environment_slug, d.id, d.job_type, d.attempts,\n                  d.last_error, d.parked_at\n             FROM dead_letters d\n             JOIN environments e ON e.id = d.environment_id\n            ORDER BY d.parked_at",
