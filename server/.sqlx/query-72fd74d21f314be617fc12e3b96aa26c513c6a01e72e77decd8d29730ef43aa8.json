  "query": "SELECT e.slug, j.job_type,\n                  count(*) AS \"total!\",\n                  count(*) FILTER (WHERE j.run_at <= now()) AS \"due!\"\n             FROM jobs j JOIN environments e ON e.id = j.environment_id\n            GROUP BY 1, 2",
