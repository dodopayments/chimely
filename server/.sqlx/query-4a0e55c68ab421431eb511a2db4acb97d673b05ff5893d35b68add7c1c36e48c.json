  "query": "UPDATE jobs SET\n               attempts = attempts + 1,\n               last_error = $3,\n               run_at = now() + make_interval(secs =>\n                   least($5::float8, $4::float8 * power(2::float8, attempts::float8))\n                       * (0.5 + random() * 0.5))\n            WHERE environment_id = $1 AND id = $2\n            RETURNING job_type, attempts, max_attempts",
