  "query": "SELECT b.created_at, b.id FROM broadcasts b\n            WHERE b.environment_id = $1\n              AND b.created_at >= $2\n              AND b.created_at <= $3\n              AND (b.created_at, b.id) > ($4, $5)\n            ORDER BY b.created_at, b.id\n            LIMIT $6",
