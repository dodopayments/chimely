  "query": "SELECT n.id, n.visible_at FROM notifications n\n            WHERE n.environment_id = $1 AND n.subscriber_id = $2\n              AND n.visible_at > $3 AND n.visible_at <= $4\n              AND (n.visible_at, n.id) > ($5, $6)\n            ORDER BY n.visible_at, n.id\n            LIMIT $7",
