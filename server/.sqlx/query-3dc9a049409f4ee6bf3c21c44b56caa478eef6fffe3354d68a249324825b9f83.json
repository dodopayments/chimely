  "query": "SELECT environment_id, id, job_type, payload, attempts, max_attempts,\n                  progress_cursor, run_at, created_at\n             FROM jobs\n            WHERE environment_id = $1 AND run_at <= now()\n            ORDER BY run_at\n            LIMIT 1\n            FOR UPDATE SKIP LOCKED",
