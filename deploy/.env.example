# Copy to deploy/.env and fill in. Used by deploy/docker-compose.yml.

# Postgres superuser password (also used in chimely's DATABASE_URL).
POSTGRES_PASSWORD=change-me

# Bootstrap admin (lockout-recovery). Password must be >= 12 characters.
CHIMELY_ADMIN_EMAIL=ops@example.com
CHIMELY_ADMIN_PASSWORD=change-me-too-long-enough

# Published image tag to run. Defaults to 0.1.0 if unset.
CHIMELY_VERSION=0.1.0
